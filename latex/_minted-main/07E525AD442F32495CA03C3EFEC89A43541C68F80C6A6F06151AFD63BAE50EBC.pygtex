            \PYG{n}{validation\PYGZus{}data}\PYG{o}{=}\PYG{p}{(}\PYG{n}{X\PYGZus{}test\PYGZus{}scaled}\PYG{p}{,} \PYG{n}{X\PYGZus{}test\PYGZus{}scaled}\PYG{p}{),}
            \PYG{n}{callbacks}\PYG{o}{=}\PYG{p}{[}\PYG{n}{early\PYGZus{}stop}\PYG{p}{],}
            \PYG{n}{verbose}\PYG{o}{=}\PYG{l+m+mi}{1}
        \PYG{p}{)}
        \PYG{k}{return} \PYG{n}{autoencoder}\PYG{p}{,} \PYG{n}{history}
